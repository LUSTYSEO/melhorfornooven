---
interface Props {
  link: string;
  label?: string;
}

const { link, label = "🛒 Ver Preço na Amazon" } = Astro.props;
---

<a
  href={link}
  target="_blank"
  rel="nofollow noopener"
  class="amazon-btn"
>
  {label}
</a>

<style>
  .amazon-btn {
    display: inline-block;
    background-color: #228B22;
    color: #ffffff !important;
    font-weight: bold;
    padding: 10px 20px;
    border-radius: 5px;
    text-decoration: none !important;
    transition: background-color 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease;
    white-space: nowrap;
    font-size: 0.95rem;
    letter-spacing: 0.02em;
    box-shadow: 0 2px 8px rgba(34, 139, 34, 0.35);
  }

  .amazon-btn:hover {
    background-color: #1a6b1a;
    transform: translateY(-2px);
    box-shadow: 0 4px 14px rgba(34, 139, 34, 0.5);
    text-decoration: none !important;
    color: #ffffff !important;
  }

  .amazon-btn:active {
    transform: translateY(0);
    box-shadow: 0 2px 6px rgba(34, 139, 34, 0.3);
  }
</style>
