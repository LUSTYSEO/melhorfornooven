---
/**
 * Home.astro - Página Inicial
 *
 * Design baseado no sistema visual do "Mestre dos Cooktops":
 * - Hero com foto de fundo + overlay escuro + badge + stats
 * - Seção Guia Destaque (card editorial)
 * - Seção Benefícios (4 ícones)
 * - Grid de Categorias (6 cards com imagem)
 * - Seção Quem Somos (2 colunas)
 * - Últimas Postagens (grid 3×3)
 */

import MainLayout from '../../layouts/MainLayout.astro';
import { getPostUrl, type BlogPermalinkStructure, type BlogUrlPrefix } from '../../utils/blog-permalink';

interface Props {
    homeData: any;
    themeId: string;
    latestPosts: any[];
    blogPermalinkStructure?: BlogPermalinkStructure;
    blogUrlPrefix?: BlogUrlPrefix;
}

const { homeData, latestPosts, blogPermalinkStructure = 'postname', blogUrlPrefix = 'blog' } = Astro.props;

const heroStats    = homeData.heroStats    || [];
const benefits     = homeData.benefits     || [];
const categories   = homeData.categories   || [];
---

<MainLayout
    title={homeData.heroTitle
        ? `${homeData.heroTitle} ${homeData.heroTitleHighlight || ''} - Melhor Forno Oven`
        : 'Melhor Air Fryer Oven do Brasil — Reviews e Guias de Compra'}
    description={homeData.heroSubtitle || 'Reviews honestos, receitas testadas e guias de compra completos para você escolher o melhor air fryer oven do mercado.'}
>

    <!-- ══════════════════════════════════════════════
         HERO — Foto de fundo + overlay + badge + stats
    ══════════════════════════════════════════════ -->
    <section
        class="mdc-hero"
        style={`background-image: url('${homeData.heroImage || '/wp-content/uploads/2026/07/hero-home-air-fryer-oven.jpg'}');`}
    >
        <div class="mdc-hero-overlay"></div>

        <div class="mdc-hero-content w-full">
            <div class="container mx-auto px-6 py-32 md:py-40">
                <div class="max-w-3xl mx-auto text-center">

                    <!-- Badge pill -->
                    {homeData.heroBadge && (
                        <div class="flex justify-center mb-8">
                            <span class="mdc-badge">
                                <span class="mdc-badge-dot"></span>
                                {homeData.heroBadge}
                            </span>
                        </div>
                    )}

                    <!-- H1 -->
                    <h1 class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-heading font-black leading-[1.08] mb-6 text-white">
                        {homeData.heroTitle || 'O guia definitivo de'}
                        {' '}
                        <span style="color: rgb(var(--primary-rgb));">
                            {homeData.heroTitleHighlight || 'Air Fryer Oven'}
                        </span>
                        {homeData.heroTitleEnd && (
                            <>
                                <br />
                                {homeData.heroTitleEnd}
                            </>
                        )}
                    </h1>

                    <!-- Subtítulo -->
                    {homeData.heroSubtitle && (
                        <p class="text-lg md:text-xl max-w-xl mx-auto mb-10 leading-relaxed" style="color: rgba(255,255,255,0.78);">
                            {homeData.heroSubtitle}
                        </p>
                    )}

                    <!-- CTAs -->
                    <div class="flex flex-col sm:flex-row gap-4 justify-center mb-16">
                        {homeData.heroCtaText && (
                            <a href={homeData.heroCtaUrl || '/melhor-air-fryer-oven'} class="mdc-btn-primary">
                                {homeData.heroCtaText}
                                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                            </a>
                        )}
                        {homeData.heroCtaSecondaryText && (
                            <a href={homeData.heroCtaSecondaryUrl || '/blog'} class="mdc-btn-outline">
                                {homeData.heroCtaSecondaryText}
                            </a>
                        )}
                    </div>

                    <!-- Stats bar -->
                    {heroStats.length > 0 && (
                        <div class="flex flex-wrap justify-center gap-3 max-w-lg mx-auto">
                            {heroStats.map((stat: any) => (
                                <div class="mdc-stat-card">
                                    <p class="mdc-stat-number">{stat.number}</p>
                                    <p class="mdc-stat-label">{stat.label}</p>
                                </div>
                            ))}
                        </div>
                    )}
                </div>
            </div>
        </div>
    </section>

    <!-- ══════════════════════════════════════════════
         SEÇÃO GUIA DESTAQUE (Card editorial)
    ══════════════════════════════════════════════ -->
    {homeData.guideTitle && (
        <section class="py-16 md:py-24" style="background: var(--blog-section-dark);">
            <div class="container mx-auto px-6">
                <div class="mdc-eyebrow">
                    <span>⭐</span>
                    Guia em Destaque
                </div>

                <div class="mdc-guide-card">
                    <div class="grid md:grid-cols-5 gap-0">
                        <!-- Imagem -->
                        {homeData.guideThumbnail && (
                            <div class="md:col-span-2 overflow-hidden" style="max-height: 260px; min-height: 200px;">
                                <img
                                    src={homeData.guideThumbnail}
                                    alt={homeData.guideTitle}
                                    class="w-full h-full object-cover"
                                    width="480"
                                    height="260"
                                    loading="lazy"
                                    decoding="async"
                                />
                            </div>
                        )}

                        <!-- Texto -->
                        <div class={`${homeData.guideThumbnail ? 'md:col-span-3' : 'md:col-span-5'} p-8 flex flex-col justify-center`}>
                            <span class="mdc-guide-tag">
                                🏆 {homeData.guideTag || 'Melhor de 2026 — Ranking Completo'}
                            </span>
                            <h2 class="text-2xl md:text-3xl font-heading font-black mb-4 leading-tight" style="color: var(--blog-text);">
                                {homeData.guideTitle}
                            </h2>
                            {homeData.guideDescription && (
                                <p class="mb-6 leading-relaxed" style="color: var(--blog-text-muted);">
                                    {homeData.guideDescription}
                                </p>
                            )}
                            <div>
                                <a href={homeData.guideCtaUrl || '/melhor-air-fryer-oven'} class="mdc-btn-primary" style="width: fit-content;">
                                    {homeData.guideCtaText || 'Ler o Guia Completo'}
                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    )}

    <!-- ══════════════════════════════════════════════
         BENEFÍCIOS — 4 ícones em linha
    ══════════════════════════════════════════════ -->
    {benefits.length > 0 && (
        <section class="py-16" style="background: var(--blog-section-alt);">
            <div class="container mx-auto px-6">
                <div class="text-center mb-12">
                    <div class="mdc-eyebrow justify-center">
                        <span>✨</span>
                        Benefícios
                    </div>
                    <h2 class="text-2xl md:text-3xl font-heading font-black" style="color: var(--blog-text);">
                        Benefícios que vão transformar sua cozinha
                    </h2>
                </div>

                <div class="grid grid-cols-2 md:grid-cols-4 gap-4 max-w-4xl mx-auto">
                    {benefits.map((b: any) => (
                        <div class="mdc-benefit-card">
                            <span class="mdc-benefit-icon">{b.icon}</span>
                            <p class="mdc-benefit-title">{b.title}</p>
                            <p class="mdc-benefit-desc">{b.description}</p>
                        </div>
                    ))}
                </div>
            </div>
        </section>
    )}

    <!-- ══════════════════════════════════════════════
         CATEGORIAS — Grid 3×2 com imagem de fundo
    ══════════════════════════════════════════════ -->
    {categories.length > 0 && (
        <section class="py-16 md:py-24" style="background: var(--blog-section-dark);">
            <div class="container mx-auto px-6">
                <div class="text-center mb-12">
                    <div class="mdc-eyebrow justify-center">
                        <span>📂</span>
                        Categorias do site
                    </div>
                    <h2 class="text-2xl md:text-3xl font-heading font-black" style="color: var(--blog-text);">
                        Explore nosso conteúdo
                    </h2>
                </div>

                <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 max-w-6xl mx-auto">
                    {categories.map((cat: any) => (
                        <a href={cat.url || '/blog'} class="mdc-cat-card">
                            <img
                                src={cat.image || '/wp-content/uploads/2025/09/como-limpar-air-fryer-oven.jpg'}
                                alt={cat.title}
                                class="mdc-cat-img"
                                width="400"
                                height="300"
                                loading="lazy"
                                decoding="async"
                            />
                            <div class="mdc-cat-overlay"></div>
                            <div class="mdc-cat-content">
                                <span class="mdc-cat-tag">
                                    {cat.tag || 'Ver Artigos'} →
                                </span>
                                <p class="mdc-cat-title">{cat.title}</p>
                            </div>
                        </a>
                    ))}
                </div>
            </div>
        </section>
    )}

    <!-- ══════════════════════════════════════════════
         QUEM SOMOS — 2 colunas
    ══════════════════════════════════════════════ -->
    {homeData.aboutTitle && (
        <section class="py-16 md:py-24" style="background: var(--blog-section-alt);">
            <div class="container mx-auto px-6">
                <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center max-w-5xl mx-auto">

                    <!-- Coluna Texto -->
                    <div class="space-y-6">
                        <div>
                            <div class="mdc-eyebrow">
                                <span>👋</span>
                                {homeData.aboutSubtitle || 'Sobre nós'}
                            </div>
                            <h2 class="text-3xl md:text-4xl font-heading font-black mt-2 mb-5 leading-tight" style="color: var(--blog-text);">
                                {homeData.aboutTitle}
                            </h2>
                        </div>

                        {homeData.aboutContent && (
                            <p class="text-lg leading-relaxed" style="color: var(--blog-text-muted);">
                                {homeData.aboutContent}
                            </p>
                        )}

                        {homeData.aboutStats && homeData.aboutStats.length > 0 && (
                            <div class="grid grid-cols-3 gap-4 pt-4">
                                {homeData.aboutStats.map((stat: any) => (
                                    <div class="text-center p-4 rounded-xl" style="background: var(--blog-surface); border: 1px solid var(--blog-border);">
                                        <p class="text-2xl font-black" style="color: rgb(var(--primary-rgb));">{stat.number}</p>
                                        <p class="text-xs mt-1" style="color: var(--blog-text-muted);">{stat.label}</p>
                                    </div>
                                ))}
                            </div>
                        )}

                        {homeData.aboutCtaText && (
                            <div class="pt-2">
                                <a href={homeData.aboutCtaUrl || '/sobre-a-isabela'} class="mdc-btn-primary" style="width: fit-content;">
                                    {homeData.aboutCtaText}
                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                                </a>
                            </div>
                        )}
                    </div>

                    <!-- Coluna Imagem -->
                    <div class="relative flex justify-center">
                        {homeData.aboutImage ? (
                            <div class="w-72 h-72 md:w-80 md:h-80 rounded-full overflow-hidden border-4 shadow-2xl" style="border-color: rgba(var(--primary-rgb), 0.4); box-shadow: 0 0 60px rgba(var(--primary-rgb), 0.2);">
                                <img
                                    src={homeData.aboutImage}
                                    alt={homeData.aboutTitle || 'Sobre Nós'}
                                    class="w-full h-full object-cover"
                                    width="320"
                                    height="320"
                                    loading="lazy"
                                    decoding="async"
                                />
                            </div>
                        ) : (
                            <div class="w-72 h-72 rounded-full bg-gradient-to-br from-primary/30 to-secondary/30 flex items-center justify-center" style="border: 2px solid rgba(var(--primary-rgb), 0.4);">
                                <span class="text-7xl">👩‍🍳</span>
                            </div>
                        )}
                        <!-- Decorative ring -->
                        <div class="absolute inset-0 flex items-center justify-center pointer-events-none">
                            <div class="w-80 h-80 md:w-96 md:h-96 rounded-full" style="border: 1px dashed rgba(var(--primary-rgb), 0.2); animation: spin 30s linear infinite;"></div>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    )}

    <!-- ══════════════════════════════════════════════
         ÚLTIMAS POSTAGENS — Grid 3×3
    ══════════════════════════════════════════════ -->
    {latestPosts && latestPosts.length > 0 && (
        <section class="py-16 md:py-24" style="background: var(--blog-section-dark);">
            <div class="container mx-auto px-6">
                <div class="text-center mb-12">
                    <div class="mdc-eyebrow justify-center">
                        <span>📰</span>
                        Nossos Posts
                    </div>
                    <h2 class="text-2xl md:text-3xl font-heading font-black" style="color: var(--blog-text);">
                        Nossos Últimos Posts
                    </h2>
                </div>

                <div class="grid md:grid-cols-3 gap-6 max-w-6xl mx-auto">
                    {latestPosts.map((post) => {
                        const thumbnail = post.data.thumbnail || post.data.metaImage;
                        const postUrl = getPostUrl(
                            { ...post, data: { ...post.data, slug: post.data.slug || post.id } },
                            blogPermalinkStructure,
                            blogUrlPrefix
                        );
                        return (
                        <a href={postUrl} class="blog-card group block" style="text-decoration: none;">
                            {thumbnail ? (
                                <div class="overflow-hidden rounded-t-2xl aspect-video" style="background: var(--blog-surface);">
                                    <img
                                        src={thumbnail}
                                        alt={post.data.title}
                                        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                                        width="420"
                                        height="236"
                                        loading="lazy"
                                        decoding="async"
                                    />
                                </div>
                            ) : (
                                <div class="overflow-hidden rounded-t-2xl aspect-video flex items-center justify-center" style="background: rgba(var(--primary-rgb),0.08); border-bottom: 1px solid var(--blog-border);">
                                    <span class="text-4xl opacity-40">🍳</span>
                                </div>
                            )}

                            <div class="p-5">
                                {post.data.category && (
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-[10px] font-bold uppercase tracking-wider mb-3" style="background: rgba(var(--primary-rgb),0.15); color: rgb(var(--primary-rgb)); border: 1px solid rgba(var(--primary-rgb),0.25);">
                                        {post.data.category}
                                    </span>
                                )}
                                <h3 class="font-bold text-base mb-3 leading-snug line-clamp-2 group-hover:text-primary transition-colors" style="color: var(--blog-text);">
                                    {post.data.title}
                                </h3>
                                <div class="flex items-center justify-between text-xs" style="color: var(--blog-text-subtle);">
                                    {post.data.publishedDate && (
                                        <span>
                                            {new Date(post.data.publishedDate).toLocaleDateString('pt-BR', {
                                                day: '2-digit', month: 'short', year: 'numeric'
                                            })}
                                        </span>
                                    )}
                                    <span class="text-primary font-semibold group-hover:translate-x-1 transition-transform inline-block">
                                        Ler →
                                    </span>
                                </div>
                            </div>
                        </a>
                        );
                    })}
                </div>

                <div class="text-center mt-10">
                    <a
                        href="/blog"
                        class="inline-flex items-center gap-2 px-8 py-4 rounded-xl font-semibold transition-all hover:border-primary/50"
                        style="background: var(--blog-surface); color: var(--blog-text); border: 1px solid var(--blog-border);"
                    >
                        Ver todos os posts
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                    </a>
                </div>
            </div>
        </section>
    )}

</MainLayout>

<style>
    .line-clamp-2 {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
    @keyframes spin {
        from { transform: rotate(0deg); }
        to   { transform: rotate(360deg); }
    }
    .mdc-eyebrow.justify-center {
        justify-content: center;
    }
</style>
